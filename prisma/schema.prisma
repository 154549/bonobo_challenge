generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// SQLite non supporta gli enum nativi di Prisma: type/priority/status sono
// String, validati a livello applicativo in src/schemas/notes.schema.ts.
model Note {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?
  type      String
  priority  String   @default("medium")
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([priority])
  @@index([status])
  @@index([createdAt])
}
